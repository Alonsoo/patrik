.notes {
	height: auto;
	border: round $primary;
	border-title-color: $primary;
}

.app_title {
	color: orange;
	margin: 2;
	text-align: center;
	width: 100%;
}

TabbedContent {
	padding: 2;
}

.excercise {
	padding: 0;	
	padding-bottom: 0;
	margin: 0;
	border: none;

	Contents { 
		padding: 1 2 1 3;
	}
}


.description {
	margin-bottom: 1;
}

.text-area--cursor-line {
	background: $surface;
}

Rule {
	margin: 0;
}
